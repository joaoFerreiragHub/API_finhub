# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/finhub

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# CORS
FRONTEND_URL=http://localhost:3000

# Email transacional (opcional)
EMAIL_PROVIDER=disabled
EMAIL_FROM_ADDRESS=no-reply@finhub.local
EMAIL_FROM_NAME=FinHub
EMAIL_APP_BASE_URL=http://localhost:5173
EMAIL_RESEND_API_KEY=
EMAIL_SENDGRID_API_KEY=
EMAIL_RESEND_BASE_URL=https://api.resend.com
EMAIL_SENDGRID_BASE_URL=https://api.sendgrid.com
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
LEGAL_VERSION=v1
LEGAL_LAST_UPDATED=2026-03-06T00:00:00.000Z
COOKIE_CONSENT_VERSION=v1

# AWS Configuration (opcional, para upload de ficheiros)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=finhub-uploads

# Upload storage provider (local|s3)
UPLOAD_STORAGE_PROVIDER=local
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=us-east-1
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_PUBLIC_BASE_URL=
UPLOAD_S3_ACCESS_KEY_ID=
UPLOAD_S3_SECRET_ACCESS_KEY=
UPLOAD_S3_FORCE_PATH_STYLE=false

# Redis (opcional, para cache)
REDIS_URL=redis://localhost:6379

# Upload Limits (em bytes)
MAX_FILE_SIZE_IMAGE=5242880
MAX_FILE_SIZE_VIDEO=104857600
MAX_FILE_SIZE_AUDIO=52428800

# Moderation Policy (opcional)
MODERATION_POLICY_AUTO_HIDE_ENABLED=false
MODERATION_POLICY_AUTO_HIDE_ACTOR_ID=
MODERATION_POLICY_AUTO_HIDE_MIN_PRIORITY=critical
MODERATION_POLICY_AUTO_HIDE_MIN_UNIQUE_REPORTERS=3
MODERATION_POLICY_AUTO_HIDE_ALLOWED_REASONS=scam,hate,sexual,violence

# Automated Moderation (opcional)
AUTOMATED_MODERATION_AUTO_HIDE_ENABLED=false
AUTOMATED_MODERATION_AUTO_HIDE_ACTOR_ID=
AUTOMATED_MODERATION_AUTO_HIDE_MIN_SEVERITY=critical
AUTOMATED_MODERATION_AUTO_HIDE_ALLOWED_RULES=spam,suspicious_link,mass_creation

# Admin Content Jobs Worker (opcional)
ADMIN_CONTENT_JOBS_MAX_ATTEMPTS=3
ADMIN_CONTENT_JOBS_WORKER_HEARTBEAT_MS=5000
ADMIN_CONTENT_JOBS_JOB_LEASE_MS=60000
ADMIN_CONTENT_JOBS_WORKER_STOP_POLL_MS=100

# Admin Permissions (opcional)
ADMIN_SCOPES_FAIL_CLOSED=false

# Admin Operational Alerts (opcional)
ADMIN_ALERT_HIDE_SPIKE_THRESHOLD=5
ADMIN_ALERT_HIDE_SPIKE_WINDOW_MINUTES=30
