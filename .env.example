# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
LOG_PATCH_CONSOLE=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017/finhub

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# CORS
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_ALL=false
CORS_ALLOW_CREDENTIALS=true

# HTTP
HTTP_JSON_BODY_LIMIT=1mb

# Google OAuth (opcional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/google/callback
GOOGLE_OAUTH_STATE_TTL_SECONDS=600

# CAPTCHA (opcional, disabled|turnstile|hcaptcha)
CAPTCHA_PROVIDER=disabled
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=
CAPTCHA_MIN_SCORE=0
CAPTCHA_TIMEOUT_MS=8000

# Email transacional (opcional)
EMAIL_PROVIDER=disabled
EMAIL_FROM_ADDRESS=no-reply@finhub.local
EMAIL_FROM_NAME=FinHub
EMAIL_APP_BASE_URL=http://localhost:5173
EMAIL_RESEND_API_KEY=
EMAIL_SENDGRID_API_KEY=
EMAIL_RESEND_BASE_URL=https://api.resend.com
EMAIL_SENDGRID_BASE_URL=https://api.sendgrid.com
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
LEGAL_VERSION=v1
LEGAL_LAST_UPDATED=2026-03-06T00:00:00.000Z
COOKIE_CONSENT_VERSION=v1

# AWS Configuration (opcional, para upload de ficheiros)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=finhub-uploads

# Upload storage provider (local|s3)
UPLOAD_STORAGE_PROVIDER=local
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=us-east-1
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_PUBLIC_BASE_URL=
UPLOAD_S3_ACCESS_KEY_ID=
UPLOAD_S3_SECRET_ACCESS_KEY=
UPLOAD_S3_FORCE_PATH_STYLE=false

# Redis (opcional, para cache)
REDIS_URL=redis://localhost:6379

# Sentry (opcional, para error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Upload Limits (em bytes)
MAX_FILE_SIZE_IMAGE=5242880
MAX_FILE_SIZE_VIDEO=104857600
MAX_FILE_SIZE_AUDIO=52428800

# Moderation Policy (opcional)
MODERATION_POLICY_AUTO_HIDE_ENABLED=false
MODERATION_POLICY_AUTO_HIDE_ACTOR_ID=
MODERATION_POLICY_AUTO_HIDE_MIN_PRIORITY=critical
MODERATION_POLICY_AUTO_HIDE_MIN_UNIQUE_REPORTERS=3
MODERATION_POLICY_AUTO_HIDE_ALLOWED_REASONS=scam,hate,sexual,violence

# Automated Moderation (opcional)
AUTOMATED_MODERATION_AUTO_HIDE_ENABLED=false
AUTOMATED_MODERATION_AUTO_HIDE_ACTOR_ID=
AUTOMATED_MODERATION_AUTO_HIDE_MIN_SEVERITY=critical
AUTOMATED_MODERATION_AUTO_HIDE_ALLOWED_RULES=spam,suspicious_link,mass_creation

# Moderation Appeals (opcional)
MODERATION_APPEAL_DEFAULT_SLA_HOURS=48

# Admin Content Jobs Worker (opcional)
ADMIN_CONTENT_JOBS_MAX_ATTEMPTS=3
ADMIN_CONTENT_JOBS_WORKER_HEARTBEAT_MS=5000
ADMIN_CONTENT_JOBS_JOB_LEASE_MS=60000
ADMIN_CONTENT_JOBS_WORKER_STOP_POLL_MS=100
ADMIN_CONTENT_JOBS_MAX_SCHEDULE_AHEAD_HOURS=720

# Admin Scope Delegation (opcional)
ADMIN_SCOPE_DELEGATION_MAX_HOURS=336
ADMIN_SCOPE_DELEGATION_MAX_SCOPES_PER_REQUEST=10
ADMIN_SCOPE_DELEGATION_RETENTION_DAYS=90

# Admin Permissions (opcional)
ADMIN_SCOPES_FAIL_CLOSED=false

# Admin Operational Alerts (opcional)
ADMIN_ALERT_HIDE_SPIKE_THRESHOLD=5
ADMIN_ALERT_HIDE_SPIKE_WINDOW_MINUTES=30
ADMIN_ALERT_JOB_STALE_MIN_COUNT=3
ADMIN_ALERT_JOB_STALE_RUNNING_MINUTES=15
ADMIN_ALERT_JOB_STALE_QUEUED_MINUTES=60
ADMIN_ALERT_JOB_RETRY_SPIKE_MIN_JOBS=5
ADMIN_ALERT_FALSE_POSITIVE_SPIKE_MIN_EVENTS=8

# Admin Communications (opcional)
ADMIN_BROADCAST_MASS_APPROVAL_MIN_RECIPIENTS=500

# Admin Ads/Partnerships (opcional)
ADMIN_ADS_DEFAULT_MIN_SECONDS_BETWEEN_IMPRESSIONS=120
ADMIN_ADS_FINANCIAL_RELEVANCE_TAGS=

# Admin Financial Tools (opcional)
ADMIN_FINANCIAL_TOOL_STOCKS_ENABLED=true
ADMIN_FINANCIAL_TOOL_ETF_ENABLED=true
ADMIN_FINANCIAL_TOOL_REIT_ENABLED=true
ADMIN_FINANCIAL_TOOL_CRYPTO_ENABLED=true
ADMIN_FINANCIAL_TOOLS_DEFAULT_MAX_SYMBOLS=25
ADMIN_FINANCIAL_TOOLS_DEFAULT_CACHE_TTL_SECONDS=300
ADMIN_FINANCIAL_TOOLS_DEFAULT_REQUESTS_PER_MINUTE=120
ADMIN_FINANCIAL_TOOLS_DEFAULT_EXPERIENCE_MODE=standard
ADMIN_FINANCIAL_TOOLS_RUNTIME_CACHE_MS=30000

# Admin Dashboard Personalization (opcional)
ADMIN_DASHBOARD_DEFAULT_REFRESH_SECONDS=120
ADMIN_DASHBOARD_MAX_WIDGETS=10
ADMIN_DASHBOARD_MAX_PINNED_FILTERS=10
ADMIN_DASHBOARD_DEFAULT_THEME=system

# Admin Bulk Import (opcional)
ADMIN_BULK_IMPORT_MAX_ROWS=2000
ADMIN_BULK_IMPORT_MAX_BYTES=1048576
ADMIN_BULK_IMPORT_MAX_STORED_ERRORS=200
ADMIN_BULK_IMPORT_MAX_STORED_RESULTS=200
ADMIN_BULK_IMPORT_JOB_RETENTION_DAYS=30

# Moderation pre-release smoke (opcional)
MODERATION_SMOKE_ADMIN_EMAIL=
MODERATION_SMOKE_ADMIN_PASSWORD=
MODERATION_SMOKE_REPORTER_EMAIL=
MODERATION_SMOKE_REPORTER_PASSWORD=
MODERATION_SMOKE_TARGET_TYPE=
MODERATION_SMOKE_TARGET_ID=
MODERATION_SMOKE_REPORT_REASON=spam

# Release E2E mandatory flows (opcional)
RELEASE_E2E_CREATOR_EMAIL=
RELEASE_E2E_CREATOR_PASSWORD=
RELEASE_E2E_ADMIN_EMAIL=
RELEASE_E2E_ADMIN_PASSWORD=
RELEASE_E2E_CAPTCHA_TOKEN=

# External content import (oEmbed MVP, opcional)
EXTERNAL_CONTENT_OEMBED_TIMEOUT_MS=7000
EXTERNAL_CONTENT_IMPORT_CACHE_TTL_SECONDS=900
INSTAGRAM_OEMBED_ACCESS_TOKEN=
